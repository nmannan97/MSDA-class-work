   "source": [
    "import numpy as np\n",
    "\n",
    "# Given data points\n",
    "x = np.array([1, 2, 3, 4])\n",
    "y = np.array([2, 3, 5, 7])\n",
    "\n",
    "# Value to estimate\n",
    "x_interp = 2.5\n",
    "\n",
    "# Linear interpolation\n",
    "y_interp = np.interp(x_interp, x, y)\n",
    "\n",
    "print(\"Estimated y at x=2.5 is:\", y_interp)"
   ]
  }
 ],
